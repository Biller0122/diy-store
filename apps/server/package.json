{
  "name": "@diy-store/server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "dev:aws-local": "DOTENV_CONFIG_PATH=../../.env.aws-local ts-node-dev -r dotenv/config --respawn --transpile-only src/index.ts",
    "dev:aws-local:win": "set DOTENV_CONFIG_PATH=../../.env.aws-local&& ts-node-dev -r dotenv/config --respawn --transpile-only src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage",
    "populate": "ts-node src/populate.ts",
    "seed:collections": "ts-node src/seed/seed-collections.ts",
    "seed:sample": "ts-node src/seed/seed-sample-data.ts",
    "seed:sample:aws-local": "DOTENV_CONFIG_PATH=../../.env.aws-local ts-node -r dotenv/config src/seed/seed-sample-data.ts",
    "seed:sample:aws-local:win": "set DOTENV_CONFIG_PATH=../../.env.aws-local&& ts-node -r dotenv/config src/seed/seed-sample-data.ts",
    "sync-algolia": "ts-node src/plugins/search/sync-products.ts",
    "search:index": "ts-node src/plugins/search/index-products.ts",
    "search:index:aws-local:win": "set DOTENV_CONFIG_PATH=../../.env.aws-local&& ts-node -r dotenv/config src/plugins/search/index-products.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1061.0",
    "bcryptjs": "^2.4.3",
    "@aws-sdk/lib-storage": "^3.1061.0",
    "@types/nodemailer": "^6.4.23",
    "@vendure/admin-ui-plugin": "^3.6.0",
    "@vendure/asset-server-plugin": "^3.6.0",
    "@vendure/core": "^3.6.0",
    "@vendure/email-plugin": "^3.6.0",
    "algoliasearch": "^5.52.1",
    "bcryptjs": "^2.4.3",
    "ioredis": "^5.11.0",
    "nodemailer": "^8.0.5",
    "pg": "^8.11.3",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.11.5",
    "@types/supertest": "^7.2.0",
    "jest": "^30.4.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
