{
  "expo": {
    "name": "DIY Driver",
    "slug": "diy-driver",
    "version": "1.0.0",
    "scheme": "diy-driver",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": { "backgroundColor": "#08080E" },
    "ios": { "supportsTablet": false, "bundleIdentifier": "mn.diy.driver" },
    "android": { "package": "mn.diy.driver", "adaptiveIcon": { "backgroundColor": "#08080E" } },
    "web": { "favicon": "./assets/favicon.png", "bundler": "metro" },
    "plugins": ["expo-router"],
    "experiments": { "typedRoutes": true }
  }
}
