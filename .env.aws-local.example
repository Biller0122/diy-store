# Local AWS/RDS development environment.
# Copy to .env.aws-local, then set DB_HOST and DB_PASSWORD from AWS RDS.
#
# IMPORTANT:
# - `vendure-dev` is often the RDS DB instance identifier, not the database name.
# - If you created the initial database as `vendure`, keep DB_NAME=vendure.
# - If you explicitly created a database named `vendure-dev`, set DB_NAME=vendure-dev.
#
# Run local server against this file:
#   npm run dev:aws-local -w @diy-store/server
#
# Seed RDS with categories, suppliers, products, drivers, and homepage banners:
#   npm run seed:sample:aws-local -w @diy-store/server

# Public/local URLs
CUSTOMER_DOMAIN=localhost
ADMIN_DOMAIN=localhost
DRIVER_DOMAIN=localhost
MERCHANT_DOMAIN=localhost
STOREFRONT_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:18080,http://localhost:18081,http://localhost:18082,http://localhost:18083
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_VENDURE_SHOP_API=http://localhost:3001/shop-api
NEXT_PUBLIC_VENDURE_ADMIN_API=http://localhost:3001/admin-api
NEXT_PUBLIC_SOCKET_URL=http://localhost:3002
GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Vendure server
PORT=3001
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=superadmin
COOKIE_SECRET=local-cookie-secret-change-before-production
REALTIME_WEBHOOK_SECRET=local-realtime-secret
REALTIME_EMBEDDED=true

# AWS RDS PostgreSQL for local development.
DB_TYPE=postgres
DB_HOST=vendure-dev.xxxxxxxxxxxx.ap-southeast-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=vendure
DB_USERNAME=vendure
# Quote the password if it contains #, spaces, $, or other shell/comment chars.
DB_PASSWORD="change-me-rds-password"
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false
# Fresh empty RDS needs this true once so Vendure creates the schema. After the
# first successful server boot and sample seed, change to false.
DB_SYNCHRONIZE=true

# Local Redis
REDIS_URL=redis://localhost:6379

# Local S3-compatible storage through MinIO.
ASSET_STORAGE=s3
S3_BUCKET=diy-store-local-assets
S3_REGION=ap-southeast-1
S3_PREFIX=vendure-assets
S3_ENDPOINT=http://localhost:9000
S3_FORCE_PATH_STYLE=true
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Keep mocks on for local testing.
PAYMENT_MOCK_MODE=true
OTP_MOCK_MODE=true
FIREBASE_MOCK_MODE=true
ALGOLIA_MOCK_MODE=true

# Optional local SMTP/payment/search credentials.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="DIY Store <noreply@example.com>"
EMAIL_FROM="DIY Store <noreply@example.com>"
ALGOLIA_APP_ID=
ALGOLIA_ADMIN_KEY=
NEXT_PUBLIC_ALGOLIA_APP_ID=
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=
NEXT_PUBLIC_ALGOLIA_INDEX_NAME=diy_products
ALGOLIA_INDEX_NAME=diy_products

# Managed AI search. Leave empty to skip automatic embedding locally.
VOYAGE_API_KEY=
ANTHROPIC_API_KEY=
EMBEDDING_MODEL=voyage-3.5
EMBEDDING_DIMENSIONS=1024
CLAUDE_QUERY_MODEL=claude-haiku-4-5-20251001
SEMANTIC_SEARCH_MIN_SCORE=0.45
