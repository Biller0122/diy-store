	email {$ACME_EMAIL}
}

{$SITE_DOMAIN} {
	encode gzip zstd

	handle /shop-api* {
		reverse_proxy server:3001 {
			header_up X-Forwarded-Host {host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	handle /admin-api* {
		reverse_proxy server:3001 {
			header_up X-Forwarded-Host {host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	handle /assets* {
		reverse_proxy server:3001 {
			header_up X-Forwarded-Host {host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	handle /mailbox* {
		reverse_proxy server:3001 {
			header_up X-Forwarded-Host {host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	handle {
		reverse_proxy web:3000 {
			header_up X-Forwarded-Host {host}
			header_up X-Forwarded-Proto {scheme}
		}
	}
}
