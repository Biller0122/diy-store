{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "react": ["../../apps/mobile-driver/node_modules/@types/react"],
      "react/jsx-runtime": ["../../apps/mobile-driver/node_modules/@types/react/jsx-runtime"],
      "react-native": ["../../apps/mobile-driver/node_modules/react-native"]
    },
    "typeRoots": ["../../apps/mobile-driver/node_modules/@types"],
    "types": ["react"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "jsx": "react-jsx"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
