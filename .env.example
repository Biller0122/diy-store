# ── Vendure DB ──────────────────────────────────────────────
VENDURE_DB_NAME=vendure
VENDURE_DB_USERNAME=vendure
VENDURE_DB_PASSWORD=vendure

# ── Strapi DB ───────────────────────────────────────────────
STRAPI_DB_NAME=strapi
STRAPI_DB_USERNAME=strapi
STRAPI_DB_PASSWORD=strapi

# ── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Vendure server (apps/server) ────────────────────────────
PORT=3001
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=superadmin
COOKIE_SECRET=change-me-in-production
STOREFRONT_URL=http://localhost:3000
EMAIL_FROM=noreply@diy-store.mn

# ── Next.js web (apps/web) ──────────────────────────────────
NEXT_PUBLIC_VENDURE_SHOP_API=http://localhost:3001/shop-api
NEXT_PUBLIC_VENDURE_ADMIN_API=http://localhost:3001/admin-api
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337
STRAPI_API_TOKEN=
NEXT_PUBLIC_SITE_URL=https://diy-store.mn

# ═══ ALGOLIA ═════════════════════════════════════════════════
# Get credentials from: https://algolia.com
# Leave empty to use mock/Vendure fallback automatically
ALGOLIA_APP_ID=
ALGOLIA_ADMIN_KEY=
NEXT_PUBLIC_ALGOLIA_APP_ID=
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=
NEXT_PUBLIC_ALGOLIA_INDEX_NAME=diy_products
ALGOLIA_INDEX_NAME=diy_products
# Set to "true" in development to skip Algolia sync
ALGOLIA_MOCK_MODE=true

# ═══ GA4 ══════════════════════════════════════════════════════
# Get from: https://analytics.google.com → Admin → Data Streams → Measurement ID
# Leave empty to log events to console in dev, skip in production
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# ═══ QPAY ═══════════════════════════════════════════════════
# Get credentials from: https://merchant.qpay.mn
# Leave empty to use mock mode automatically
QPAY_USERNAME=
QPAY_PASSWORD=
QPAY_INVOICE_CODE=
QPAY_URL=https://merchant.qpay.mn/v2

# ═══ MONPAY ══════════════════════════════════════════════════
# Get credentials from: https://monpay.mn/business
# Leave empty to use mock mode automatically
MONPAY_USERNAME=
MONPAY_CLIENT_ID=
MONPAY_CLIENT_SECRET=
MONPAY_URL=https://wallet.monpay.mn

# ═══ CARD PSP ════════════════════════════════════════════════
# Connect your acquiring bank (Golomt, Khan Bank Merchant, etc.)
# Leave empty to use mock mode automatically
CARD_PSP_URL=
CARD_PSP_MERCHANT_ID=
CARD_PSP_SECRET=

# Set to "true" in development to force mock payments even if credentials exist
PAYMENT_MOCK_MODE=true

# ═══ TEST ACCOUNTS (dev only) ════════════════════════════════
# Customer: email login via /account/login (dev fallback: any email/password works)
TEST_CUSTOMER_EMAIL=test@diystore.mn
TEST_CUSTOMER_PASSWORD=test1234
# Supplier OTP login (dev OTP: 1234)
TEST_SUPPLIER_PHONE=88001122
# Driver OTP login (dev OTP: 1234)
TEST_DRIVER_PHONE=77009988
# Admin credentials
ADMIN_EMAIL=admin@diystore.mn
ADMIN_PASSWORD=superadmin

# ── Strapi CMS (apps/cms) ───────────────────────────────────
HOST=0.0.0.0
CMS_PORT=1337
APP_KEYS=change-me-key1,change-me-key2
API_TOKEN_SALT=change-me-salt
ADMIN_JWT_SECRET=change-me-admin-jwt
TRANSFER_TOKEN_SALT=change-me-transfer-salt
JWT_SECRET=change-me-jwt
