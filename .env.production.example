# Domain / public URLs
CUSTOMER_DOMAIN=shop.example.com
ADMIN_DOMAIN=admin.example.com
DRIVER_DOMAIN=driver.example.com
MERCHANT_DOMAIN=merchant.example.com
ACME_EMAIL=admin@example.com
STOREFRONT_URL=https://shop.example.com
CORS_ALLOWED_ORIGINS=https://shop.example.com,https://admin.example.com,https://driver.example.com,https://merchant.example.com
NEXT_PUBLIC_SITE_URL=https://shop.example.com
NEXT_PUBLIC_VENDURE_SHOP_API=/shop-api
NEXT_PUBLIC_VENDURE_ADMIN_API=/admin-api
NEXT_PUBLIC_SOCKET_URL=https://shop.example.com

# Internal Docker URLs
INTERNAL_VENDURE_SHOP_API=http://server:3001/shop-api
INTERNAL_VENDURE_ADMIN_API=http://server:3001/admin-api

# Vendure
PORT=3001
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=change-me-long-password
COOKIE_SECRET=change-this-to-a-very-long-random-secret
EMAIL_FROM="DIY Store <noreply@example.com>"

# RDS PostgreSQL. The production Compose stack does not run Postgres locally.
DB_TYPE=postgres
DB_HOST=your-rds-endpoint.ap-southeast-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=vendure
DB_USERNAME=vendure
DB_PASSWORD=change-me-db-password
# Fresh empty RDS needs this true on first boot because this repo does not ship
# DB migrations yet. After the first successful deploy, change to false.
DB_SYNCHRONIZE=true

# Vendure assets in S3. Prefer an EC2 IAM instance role over AWS keys here.
ASSET_STORAGE=s3
S3_BUCKET=diy-store-prod-assets
S3_REGION=ap-southeast-1
S3_PREFIX=vendure-assets
# S3_ENDPOINT and S3_FORCE_PATH_STYLE are only for S3-compatible stores.
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=false

# Supplier email OTP. Leave SMTP_HOST empty to log OTP in server logs.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="DIY Store <noreply@example.com>"

# Payments/search
# Keep mocks true only for private smoke tests. Flip them false before public launch.
PAYMENT_MOCK_MODE=true
OTP_MOCK_MODE=true
FIREBASE_MOCK_MODE=true
ALGOLIA_MOCK_MODE=true
ALGOLIA_APP_ID=
ALGOLIA_ADMIN_KEY=
NEXT_PUBLIC_ALGOLIA_APP_ID=
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=
NEXT_PUBLIC_ALGOLIA_INDEX_NAME=diy_products
ALGOLIA_INDEX_NAME=diy_products
# ── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# Shared secret for realtime-server -> api-server driver decision webhooks.
REALTIME_WEBHOOK_SECRET=change-this-realtime-webhook-secret
