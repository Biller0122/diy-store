# Domain / public URLs
SITE_DOMAIN=52.77.245.218
CUSTOMER_DOMAIN=shop.example.com
ADMIN_DOMAIN=admin.example.com
DRIVER_DOMAIN=driver.example.com
MERCHANT_DOMAIN=merchant.example.com
ACME_EMAIL=admin@example.com
STOREFRONT_URL=http://52.77.245.218
CORS_ALLOWED_ORIGINS=https://shop.example.com,https://admin.example.com,https://driver.example.com,https://merchant.example.com
NEXT_PUBLIC_SITE_URL=http://52.77.245.218
NEXT_PUBLIC_VENDURE_SHOP_API=/shop-api
NEXT_PUBLIC_VENDURE_ADMIN_API=/admin-api
NEXT_PUBLIC_SOCKET_URL=http://52.77.245.218:3002

# Internal Docker URLs
INTERNAL_VENDURE_SHOP_API=http://server:3001/shop-api
INTERNAL_VENDURE_ADMIN_API=http://server:3001/admin-api

# Vendure
PORT=3001
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=change-me-long-password
COOKIE_SECRET=change-this-to-a-very-long-random-secret
EMAIL_FROM="DIY Store <noreply@example.com>"

# Database
DB_NAME=vendure
DB_USERNAME=vendure
DB_PASSWORD=change-me-db-password
# Fresh Docker Postgres needs this true on first boot because this repo does not
# ship DB migrations yet. After the first successful deploy, change to false so
# schema changes cannot surprise production data.
DB_SYNCHRONIZE=true

# Supplier email OTP. Leave SMTP_HOST empty to log OTP in server logs.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="DIY Store <noreply@example.com>"

# Payments/search
PAYMENT_MOCK_MODE=true
ALGOLIA_MOCK_MODE=true
ALGOLIA_APP_ID=
ALGOLIA_ADMIN_KEY=
NEXT_PUBLIC_ALGOLIA_APP_ID=
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=
NEXT_PUBLIC_ALGOLIA_INDEX_NAME=diy_products
ALGOLIA_INDEX_NAME=diy_products
# ── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# Shared secret for realtime-server -> api-server driver decision webhooks.
REALTIME_WEBHOOK_SECRET=change-this-realtime-webhook-secret

# Keep true until real SMS/email delivery is configured for OTP.
OTP_MOCK_MODE=true
